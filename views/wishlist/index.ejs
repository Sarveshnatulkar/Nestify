<%layout("/layouts/boilerplate")-%>

<div class="row mt-4">
  <div class="col-12">

    <div class="d-flex align-items-center justify-content-between mb-4">
      <h2 class="page-title mb-0">
        <i class="fa-solid fa-heart me-2" style="color:var(--brand);"></i>
        My Wishlist
      </h2>
      <% if (wishlist.length > 0) { %>
        <span style="font-size:0.9rem; color:var(--text-secondary);">
          <%= wishlist.length %> saved <%= wishlist.length === 1 ? 'place' : 'places' %>
        </span>
      <% } %>
    </div>

    <% if (wishlist.length === 0) { %>
      <!-- Empty state -->
      <div class="wishlist-empty">
        <i class="fa-regular fa-heart"></i>
        <h4>No saved places yet</h4>
        <p>Click the heart on any listing to save it here.</p>
        <a href="/listings" class="btn btn-brand mt-2">Explore listings</a>
      </div>

    <% } else { %>
      <div class="row row-cols-xl-3 row-cols-md-2 row-cols-1 g-4">
        <% for (let listing of wishlist) { %>
          <div class="col">
            <div class="listing-card-wrapper">
              <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="listing-card">
                  <img
                    src="<%= listing.image.url %>"
                    class="card-img-top"
                    alt="<%= listing.title %>"
                    loading="lazy"
                  />
                  <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mt-1">
                      <p class="card-title-text mb-0"><%= listing.title %></p>
                      <% if (listing.category) { %>
                        <span class="card-category-tag"><%= listing.category %></span>
                      <% } %>
                    </div>
                    <p class="card-location-text mb-0"><%= listing.location %>, <%= listing.country %></p>
                    <p class="card-price-text mb-0"><strong>₹<%= listing.price.toLocaleString("en-IN") %></strong> / night</p>
                  </div>
                </div>
              </a>

              <!-- Remove from wishlist -->
              <form method="post"
                    action="/wishlist/<%= listing._id %>?_method=DELETE"
                    class="wishlist-remove-form">
                <button type="submit"
                        class="wishlist-heart-btn saved"
                        title="Remove from wishlist"
                        aria-label="Remove from wishlist">
                  <i class="fa-solid fa-heart"></i>
                </button>
              </form>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>

  </div>
</div>
