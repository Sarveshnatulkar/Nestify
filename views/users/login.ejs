<%layout("/layouts/boilerplate")-%>

<div class="d-flex justify-content-center align-items-start py-5">
  <div class="auth-card">

    <div class="text-center mb-1">
      <i class="fa-solid fa-compass auth-logo"></i>
    </div>
    <h2 class="auth-title text-center">Welcome back</h2>
    <p class="auth-subtitle text-center">Log in to your Nestify account</p>

    <form action="/login" method="post" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input name="username" id="username" type="text" class="form-control"
               placeholder="Your username" required />
        <div class="invalid-feedback">Please enter your username.</div>
      </div>
      <div class="mb-4">
        <label for="password" class="form-label">Password</label>
        <input name="password" id="password" type="password" class="form-control"
               placeholder="Your password" required />
        <div class="invalid-feedback">Please enter your password.</div>
      </div>
      <button type="submit" class="btn btn-brand w-100">Log in</button>
    </form>

    <p class="auth-footer-text">
      Don't have an account? <a href="/signup">Sign up</a>
    </p>

  </div>
</div>
