<div class="flash-container">

  <% if (success && success.length) { %>
  <div class="flash-toast flash-success alert alert-dismissible fade show" role="alert">
    <i class="fa-solid fa-circle-check flash-icon"></i>
    <span><%= success %></span>
    <button type="button" class="btn-close btn-close-sm ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
  <% } %>

  <% if (error && error.length) { %>
  <div class="flash-toast flash-error alert alert-dismissible fade show" role="alert">
    <i class="fa-solid fa-circle-exclamation flash-icon"></i>
    <span><%= error %></span>
    <button type="button" class="btn-close btn-close-sm ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
  <% } %>

</div>
