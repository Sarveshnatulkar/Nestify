<%layout("/layouts/boilerplate")-%>

<div class="row my-4">
  <div class="col-lg-7 col-md-9 col-12 mx-auto">
    <h2 class="page-title">List your property</h2>

    <div class="form-card">
      <form method="post" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input id="title" name="listing[title]" type="text" class="form-control"
                 placeholder="Give your place a catchy title" required />
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">Please add a title.</div>
        </div>

        <div class="mb-3">
          <label for="description" class="form-label">Description</label>
          <textarea id="description" name="listing[description]" class="form-control" rows="4"
                    placeholder="Describe what makes your place special" required></textarea>
          <div class="invalid-feedback">Please add a description.</div>
        </div>

        <!-- ── Image upload ───────────────────────────────────── -->
        <div class="mb-3">
          <label class="form-label">
            Photos
            <span class="upload-hint">Up to 5 images · JPG, PNG, WebP · Max 8 MB each</span>
          </label>

          <div class="upload-drop-zone" id="dropZone">
            <input id="images" name="listing[images]" type="file"
                   accept="image/jpeg,image/png,image/webp"
                   multiple class="upload-file-input" />
            <div class="upload-drop-body">
              <i class="fa-solid fa-cloud-arrow-up upload-icon"></i>
              <p class="upload-drop-text">Drag & drop photos here, or <span class="upload-browse">browse</span></p>
              <p class="upload-drop-hint">First photo will be the cover image</p>
            </div>
          </div>

          <!-- Preview grid — populated by JS -->
          <div class="upload-preview-grid" id="previewGrid"></div>
          <div class="invalid-feedback d-block" id="imageError" style="display:none!important;"></div>
        </div>
        <!-- ──────────────────────────────────────────────────── -->

        <div class="row g-3 mb-3">
          <div class="col-md-4">
            <label for="price" class="form-label">Price per night (₹)</label>
            <input id="price" name="listing[price]" type="number" min="0" class="form-control"
                   placeholder="0" required />
            <div class="invalid-feedback">Enter a valid price.</div>
          </div>
          <div class="col-md-8">
            <label for="country" class="form-label">Country</label>
            <input id="country" name="listing[country]" type="text" class="form-control"
                   placeholder="e.g. India" required />
            <div class="invalid-feedback">Enter a country.</div>
          </div>
        </div>

        <div class="mb-3">
          <label for="location" class="form-label">Location</label>
          <input id="location" name="listing[location]" type="text" class="form-control"
                 placeholder="City, neighbourhood or landmark" required />
          <div class="invalid-feedback">Enter a location.</div>
        </div>

        <div class="mb-4">
          <label for="category" class="form-label">Category</label>
          <select id="category" name="listing[category]" class="form-control" required>
            <option value="">Select a category</option>
            <% ["Rooms","Amazing views","Castle","Camping","Mountains","Amazing pools","Arctic","Desert","Boat","Play"].forEach(c => { %>
              <option value="<%= c %>"><%= c %></option>
            <% }); %>
          </select>
          <div class="invalid-feedback">Select a category.</div>
        </div>

        <button type="submit" class="btn btn-brand px-4">Create Listing</button>

      </form>
    </div>
  </div>
</div>
