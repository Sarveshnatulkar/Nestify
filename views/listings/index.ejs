<%layout("/layouts/boilerplate")-%>

<!-- Filter bar -->
<div id="filters">
  <div class="filters"><i class="fa-solid fa-bed"></i><p>Rooms</p></div>
  <div class="filters"><i class="fa-solid fa-leaf"></i><p>Amazing views</p></div>
  <div class="filters"><i class="fa-brands fa-fort-awesome"></i><p>Castle</p></div>
  <div class="filters"><i class="fa-solid fa-campground"></i><p>Camping</p></div>
  <div class="filters"><i class="fa-solid fa-mountain"></i><p>Mountains</p></div>
  <div class="filters"><i class="fa-solid fa-person-swimming"></i><p>Amazing pools</p></div>
  <div class="filters"><i class="fa-solid fa-snowflake"></i><p>Arctic</p></div>
  <div class="filters"><i class="fa-solid fa-sun"></i><p>Desert</p></div>
  <div class="filters"><i class="fa-solid fa-ship"></i><p>Boat</p></div>
  <div class="filters"><i class="fa-solid fa-volleyball"></i><p>Play</p></div>
</div>

<!-- Result summary — only shown during an active search -->
<% if (q && q.trim() !== '') { %>
  <div class="d-flex align-items-center justify-content-between mt-3 mb-1">
    <p class="mb-0" style="font-size:0.9rem; color:var(--text-secondary);">
      <% if (resultCount > 0) { %>
        <strong style="color:var(--text-primary);"><%= resultCount %></strong>
        <%= resultCount === 1 ? 'place' : 'places' %> found for
        "<strong style="color:var(--text-primary);"><%= q %></strong>"
      <% } else { %>
        No results for "<strong style="color:var(--text-primary);"><%= q %></strong>"
      <% } %>
    </p>
    <a href="/listings" class="btn btn-ghost btn-sm">Clear</a>
  </div>
<% } %>

<!-- Listings grid -->
<div class="row row-cols-xl-3 row-cols-md-2 row-cols-1 mt-2 g-4">

  <% if (allListings.length === 0) { %>
    <div class="col-12 text-center py-5">
      <% if (q && q.trim() !== '') { %>
        <i class="fa-solid fa-magnifying-glass fa-2x mb-3" style="color:var(--text-light);"></i>
        <h5 style="color:var(--text-primary);">No places found</h5>
        <p style="color:var(--text-secondary); font-size:0.9rem;">
          We couldn't find anything matching "<strong><%= q %></strong>".<br>
          Try searching by city, country, or property name.
        </p>
        <a href="/listings" class="btn btn-ghost mt-1">Browse all listings</a>
      <% } else { %>
        <i class="fa-solid fa-house fa-2x mb-3" style="color:var(--text-light);"></i>
        <p style="color:var(--text-secondary);">No listings available yet.</p>
      <% } %>
    </div>

  <% } else { %>
    <% for (let listing of allListings) { %>
      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="listing-card">
            <img
              src="<%= listing.image.url %>"
              class="card-img-top"
              alt="<%= listing.title %>"
              loading="lazy"
            />
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start mt-1">
                <p class="card-title-text mb-0"><%= listing.title %></p>
              </div>
              <p class="card-location-text mb-0"><%= listing.location %>, <%= listing.country %></p>
              <p class="card-price-text mb-0"><strong>₹<%= listing.price.toLocaleString("en-IN") %></strong> / night</p>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  <% } %>

</div>
